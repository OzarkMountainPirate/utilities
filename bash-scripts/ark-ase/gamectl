#!/bin/bash
#############################################################
## Name          : gamectl
## Version       : 1.1
## Date          : 2026-07-12
## Maintainer    : OzarkMountainPirate - github.com/OzarkMountainPirate/utilities
## Credit        : Design inspired by LHammonds' ark-bash toolkit
##               : (github.com/LHammonds/ark-bash).
## Compatibility : Ubuntu Server 24.04 LTS (Debian 13 - Testing)  |  ARK: Survival Evolved (app 376030)
## Requirements  : steamcmd, rsync, mcrcon (RCON), systemd
## Purpose       : One tool to install, run, cluster, mod, back up, and update
##                 ARK: Survival Evolved dedicated server instances on Linux.
## Exit Codes    : 0 = success, 1 = usage/arg error, 2 = runtime error
###################### CHANGE LOG ###########################
## DATE       VER WHO WHAT WAS CHANGED
## ---------- --- --- ---------------------------------------
## 2026-07-12 1.1 OMP Retry flaky steamcmd downloads (STEAM_RETRIES, resumes from last position); add version subcommand
## 2026-07-04 1.0 OMP Created (modern rewrite for 24.04).
#############################################################

set -euo pipefail

CONF="${GAMECTL_CONF:-/etc/gamectl.conf}"
[ -r "$CONF" ] || { echo "ERROR: config not found: $CONF" >&2; exit 2; }
# shellcheck source=/dev/null
source "$CONF"

TEMPLATE="${ARK_ROOT}/template"
INSTANCES_DIR="${ARK_ROOT}/instances"
BACKUP_DIR="${ARK_ROOT}/bak"
CLUSTER_DIR="${ARK_ROOT}/cluster"
UNIT="/etc/systemd/system/ark@.service"
VERSION="1.1"

## ---- small helpers ------------------------------------------------------
log()  { printf '[gamectl] %s\n' "$*"; }
err()  { printf '[gamectl] ERROR: %s\n' "$*" >&2; }
die()  { err "$*"; exit 2; }

## Resolve an instance's fields into globals: I_MAP I_GAME I_QUERY I_RCON
resolve() {
  local key="$1"
  [ -n "${INSTANCES[$key]+x}" ] || die "unknown instance '$key' (check $CONF)"
  # shellcheck disable=SC2206
  local parts=(${INSTANCES[$key]})
  I_MAP="${parts[0]}"; I_GAME="${parts[1]}"; I_QUERY="${parts[2]}"; I_RCON="${parts[3]}"
}

## Expand "all" to every instance key, or echo the single key back.
keys_for() {
  if [ "${1:-}" = "all" ] || [ -z "${1:-}" ]; then
    printf '%s\n' "${!INSTANCES[@]}"
  else
    printf '%s\n' "$1"
  fi
}


as_ark() { sudo -u "$ARK_USER" -H "$@"; }
## steamcmd is notoriously flaky on large downloads (CDN stalls, the
## "Missing configuration" first-run race, 0x402 aborts) but resumes cleanly
## from wherever it died. Retry before declaring real failure. Override the
## attempt count via STEAM_RETRIES in gamectl.conf or the environment.
STEAM_RETRIES="${STEAM_RETRIES:-4}"
steam_app_update() {
  local attempt=1 rc=0
  while :; do
    as_ark "$STEAMCMD" +force_install_dir "$TEMPLATE" +login anonymous \
      +app_update "$ARK_APPID" validate +quit && return 0
    rc=$?
    if [ "$attempt" -ge "$STEAM_RETRIES" ]; then
      err "steamcmd failed (rc=$rc) after ${STEAM_RETRIES} attempts"
      return "$rc"
    fi
    err "steamcmd failed (rc=$rc), attempt ${attempt}/${STEAM_RETRIES} -- retrying in 10s (resumes from last position)"
    attempt=$((attempt + 1))
    sleep 10
  done
}


## ---- launch command builder --------------------------------------------
## Writes instances/<key>/server-start.sh from config. Regenerated on
## create/sync so port/mod/cluster changes always take effect.
write_start_script() {
  local key="$1"; resolve "$key"
  local dir="${INSTANCES_DIR}/${key}"
  local bin="${dir}/ShooterGame/Binaries/Linux"
  local opts="${I_MAP}?listen"
  opts+="?SessionName=${key}"
  opts+="?ServerAdminPassword=${ADMIN_PASSWORD}"
  opts+="?RCONEnabled=True?RCONPort=${I_RCON}"
  opts+="?Port=${I_GAME}?QueryPort=${I_QUERY}"

  cat > "${bin}/server-start.sh" <<SH
#!/bin/bash
# Generated by gamectl -- do not edit by hand; edit gamectl.conf and re-sync.
cd "${bin}"
exec ./ShooterGameServer "${opts}" \\
  -server -log -automanagedmods \\
  -clusterid=${CLUSTER_ID} -ClusterDirOverride=${CLUSTER_DIR} \\
  -NoTransferFromFiltering
SH
  chmod 0755 "${bin}/server-start.sh"
  chown "${ARK_USER}:${ARK_USER}" "${bin}/server-start.sh"
}

## Write ActiveMods= into an instance's GameUserSettings.ini [ServerSettings].
apply_mods() {
  local key="$1"
  local cfg="${INSTANCES_DIR}/${key}/ShooterGame/Saved/Config/LinuxServer/GameUserSettings.ini"
  as_ark mkdir -p "$(dirname "$cfg")"
  as_ark touch "$cfg"
  # remove any existing ActiveMods line, then set the current one
  as_ark sed -i '/^ActiveMods=/d' "$cfg"
  if [ -n "${MODS}" ]; then
    if grep -q '^\[ServerSettings\]' "$cfg"; then
      as_ark sed -i "/^\[ServerSettings\]/a ActiveMods=${MODS}" "$cfg"
    else
      printf '[ServerSettings]\nActiveMods=%s\n' "${MODS}" | as_ark tee -a "$cfg" >/dev/null
    fi
  fi
}

## The known Linux -automanagedmods fix: make steamcmd + steamapps reachable
## from inside the server's ThirdParty SteamCMD path so the server can fetch
## and unpack workshop mods itself.
setup_mod_symlinks() {
  local key="$1"
  local scmd="${INSTANCES_DIR}/${key}/Engine/Binaries/ThirdParty/SteamCMD/Linux"
  as_ark mkdir -p "$scmd"
  as_ark ln -sfn "${STEAM_HOME}/.steam/steamcmd/steamcmd.sh" "${scmd}/steamcmd.sh" 2>/dev/null || true
  as_ark ln -sfn "${STEAM_HOME}/.steam/steamapps" "${scmd}/steamapps" 2>/dev/null || true
}

## ---- subcommands --------------------------------------------------------
cmd_install() {
  [ "$(id -u)" -eq 0 ] || die "install must run as root"
  id "$ARK_USER" &>/dev/null || { log "creating user $ARK_USER"; adduser --system --group --home "$STEAM_HOME" "$ARK_USER"; }
  command -v "$STEAMCMD" >/dev/null || die "steamcmd not found at $STEAMCMD (apt install steamcmd)"
  command -v mcrcon      >/dev/null || err "mcrcon not found -- 'rcon' subcommand will not work until installed"
  mkdir -p "$TEMPLATE" "$INSTANCES_DIR" "$BACKUP_DIR" "$CLUSTER_DIR"
  chown -R "${ARK_USER}:${ARK_USER}" "$ARK_ROOT"
  log "downloading ARK server (app ${ARK_APPID}) into template..."
  steam_app_update || die "ARK download failed after ${STEAM_RETRIES} steamcmd attempts"
  log "install complete. Next: 'gamectl create <instance>' for each map."
}

cmd_update() {
  [ "$(id -u)" -eq 0 ] || die "update must run as root"
  log "updating template (app ${ARK_APPID})..."
  steam_app_update || die "ARK download failed after ${STEAM_RETRIES} steamcmd attempts"
  log "template updated. Run 'gamectl sync all' to roll it out (instances must be stopped)."
}

cmd_create() {
  [ "$(id -u)" -eq 0 ] || die "create must run as root"
  local key="${1:?usage: gamectl create <instance>}"; resolve "$key"
  [ -d "$TEMPLATE/ShooterGame" ] || die "template missing -- run 'gamectl install' first"
  local dir="${INSTANCES_DIR}/${key}"
  log "creating instance '${key}' (${I_MAP}) from template..."
  as_ark mkdir -p "$dir"
  as_ark rsync -a --delete --exclude 'ShooterGame/Saved' "$TEMPLATE/" "$dir/"
  setup_mod_symlinks "$key"
  apply_mods "$key"
  write_start_script "$key"
  install_unit
  systemctl enable "ark@${key}" >/dev/null 2>&1 || true
  log "instance '${key}' ready. Start with: gamectl start ${key}"
}

cmd_sync() {
  [ "$(id -u)" -eq 0 ] || die "sync must run as root"
  local key
  for key in $(keys_for "${1:-all}"); do
    resolve "$key"
    if systemctl is-active --quiet "ark@${key}"; then
      err "instance '${key}' is running -- stop it before sync; skipping"; continue
    fi
    log "syncing template -> ${key} (saves preserved)..."
    as_ark rsync -a --delete --exclude 'ShooterGame/Saved' "$TEMPLATE/" "${INSTANCES_DIR}/${key}/"
    setup_mod_symlinks "$key"; apply_mods "$key"; write_start_script "$key"
  done
}

cmd_start() {
  local key; for key in $(keys_for "${1:-all}"); do resolve "$key"; log "starting ${key}..."; systemctl start "ark@${key}"; done
}

## Graceful stop: save the world over RCON, tell the server to exit, then
## stop the unit. Prevents the save corruption a hard kill can cause.
cmd_stop() {
  local key
  for key in $(keys_for "${1:-all}"); do
    resolve "$key"
    if systemctl is-active --quiet "ark@${key}"; then
      log "saving + stopping ${key}..."
      mcrcon -H 127.0.0.1 -P "$I_RCON" -p "$ADMIN_PASSWORD" "saveworld" >/dev/null 2>&1 || err "${key}: RCON saveworld failed (stopping anyway)"
      mcrcon -H 127.0.0.1 -P "$I_RCON" -p "$ADMIN_PASSWORD" "doexit"    >/dev/null 2>&1 || true
      sleep 5
    fi
    systemctl stop "ark@${key}" || true
  done
}

cmd_restart() { cmd_stop "${1:-all}"; cmd_start "${1:-all}"; }

cmd_status() {
  printf '%-16s %-14s %-8s %-8s %-8s\n' INSTANCE MAP GAME QUERY STATE
  local key
  for key in $(keys_for all); do
    resolve "$key"
    local state; state=$(systemctl is-active "ark@${key}" 2>/dev/null || echo inactive)
    printf '%-16s %-14s %-8s %-8s %-8s\n' "$key" "$I_MAP" "$I_GAME" "$I_QUERY" "$state"
  done
}

cmd_rcon() {
  local key="${1:?usage: gamectl rcon <instance> <command...>}"; shift; resolve "$key"
  command -v mcrcon >/dev/null || die "mcrcon not installed"
  mcrcon -H 127.0.0.1 -P "$I_RCON" -p "$ADMIN_PASSWORD" "$*"
}

## Re-apply the mod list to all instances and (re)start so -automanagedmods
## pulls + unpacks them. Server-side download; no external mod tool needed.
cmd_mods() {
  [ "$(id -u)" -eq 0 ] || die "mods must run as root"
  local key
  for key in $(keys_for "${1:-all}"); do
    resolve "$key"; setup_mod_symlinks "$key"; apply_mods "$key"
    log "${key}: ActiveMods set to '${MODS:-<none>}'"
  done
  log "restart instances to download/unpack: gamectl restart all"
}

cmd_backup() {
  [ "$(id -u)" -eq 0 ] || die "backup must run as root"
  local key ts; ts="$(date +%Y%m%d-%H%M%S)"
  as_ark mkdir -p "$BACKUP_DIR"
  for key in $(keys_for "${1:-all}"); do
    resolve "$key"
    local saved="${INSTANCES_DIR}/${key}/ShooterGame/Saved"
    [ -d "$saved" ] || { err "${key}: no Saved dir yet; skipping"; continue; }
    local was_up=0
    systemctl is-active --quiet "ark@${key}" && { was_up=1; cmd_stop "$key"; }
    log "archiving ${key}..."
    as_ark tar -czf "${BACKUP_DIR}/${key}-${ts}.tar.gz" -C "$saved" .
    [ "$was_up" -eq 1 ] && cmd_start "$key"
  done
  log "purging backups older than ${BACKUP_KEEP_DAYS} days..."
  find "$BACKUP_DIR" -name '*.tar.gz' -mtime "+${BACKUP_KEEP_DAYS}" -delete 2>/dev/null || true
}

cmd_restore() {
  [ "$(id -u)" -eq 0 ] || die "restore must run as root"
  local key="${1:?usage: gamectl restore <instance> [archive]}"; resolve "$key"
  local archive="${2:-}"
  [ -n "$archive" ] || archive="$(ls -1t "${BACKUP_DIR}/${key}-"*.tar.gz 2>/dev/null | head -1 || true)"
  [ -n "$archive" ] && [ -f "$archive" ] || die "no backup archive found for '${key}'"
  systemctl is-active --quiet "ark@${key}" && cmd_stop "$key"
  local saved="${INSTANCES_DIR}/${key}/ShooterGame/Saved"
  log "restoring ${key} from $(basename "$archive")..."
  as_ark mkdir -p "$saved"
  as_ark tar -xzf "$archive" -C "$saved"
  log "restored. Start with: gamectl start ${key}"
}

install_unit() {
  cat > "$UNIT" <<UNIT
[Unit]
Description=ARK: Survival Evolved dedicated server (%i)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=${ARK_USER}
Group=${ARK_USER}
WorkingDirectory=${INSTANCES_DIR}/%i/ShooterGame/Binaries/Linux
ExecStart=${INSTANCES_DIR}/%i/ShooterGame/Binaries/Linux/server-start.sh
LimitNOFILE=100000
Restart=on-failure
RestartSec=20

[Install]
WantedBy=multi-user.target
UNIT
  systemctl daemon-reload
}

usage() {
  cat <<USAGE
gamectl -- ARK: Survival Evolved server management

  gamectl install                 First-time setup + download server to template
  gamectl update                  Update the template from Steam
  gamectl create <instance>       Provision an instance from the template
  gamectl sync   [instance|all]   Roll template updates into stopped instance(s)
  gamectl start  [instance|all]   Start instance(s)
  gamectl stop   [instance|all]   Save + gracefully stop instance(s)
  gamectl restart[instance|all]   Stop then start
  gamectl status                  Show all instances and their state
  gamectl rcon   <instance> <cmd> Send an RCON command (via mcrcon)
  gamectl mods   [instance|all]   Apply MODS list; server auto-downloads on start
  gamectl backup [instance|all]   Save-safe archive of instance save data
  gamectl restore <instance> [archive]  Restore newest (or given) backup

Instances and settings live in ${CONF}.
USAGE
}

## ---- dispatch -----------------------------------------------------------
cmd="${1:-}"; shift || true
case "$cmd" in
  install) cmd_install "$@" ;;
  update)  cmd_update  "$@" ;;
  create)  cmd_create  "$@" ;;
  sync)    cmd_sync    "$@" ;;
  start)   cmd_start   "$@" ;;
  stop)    cmd_stop    "$@" ;;
  restart) cmd_restart "$@" ;;
  status)  cmd_status  "$@" ;;
  rcon)    cmd_rcon    "$@" ;;
  mods)    cmd_mods    "$@" ;;
  backup)  cmd_backup  "$@" ;;
  restore) cmd_restore "$@" ;;
  version) echo "gamectl ${VERSION}" ;;
  ""|-h|--help|help) usage ;;
  *) err "unknown command '$cmd'"; usage; exit 1 ;;
esac
