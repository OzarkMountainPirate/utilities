# =============================================================================
# /etc/restic/env — restic credentials and repository location.
#
# Setup:
#   sudo install -m 600 -o root -g root env.example /etc/restic/env
#   sudo "${EDITOR:-vi}" /etc/restic/env        # fill in the real values
#
# This file is sourced by the backup scripts with `set -a`, so every variable
# below becomes an environment variable visible to restic.
#
# DO NOT commit the real /etc/restic/env to version control.
# =============================================================================

# ---- Repository -------------------------------------------------------------
# Backblaze B2 (format: b2:BUCKET_NAME:PATH_PREFIX):
RESTIC_REPOSITORY=b2:your-bucket-name:hostname

# Other backends (uncomment one instead):
#   RESTIC_REPOSITORY=s3:s3.us-east-1.amazonaws.com/your-bucket/prefix
#   RESTIC_REPOSITORY=sftp:backupuser@backup.example.lan:/srv/restic
#   RESTIC_REPOSITORY=/mnt/external/restic-repo

# ---- Repository password ----------------------------------------------------
# Keep the password in its own root-only file rather than inline here.
# Generate one with:  openssl rand -base64 32 | sudo tee /etc/restic/password
# then:               sudo chmod 600 /etc/restic/password
RESTIC_PASSWORD_FILE=/etc/restic/password

# ---- Backend credentials ----------------------------------------------------
# Backblaze B2. NOTE: B2_ACCOUNT_ID is the keyID of a scoped Application Key,
# NOT your master account ID — the naming is historical. Create a bucket-scoped
# Application Key (read+write) in the B2 console and paste its values here.
B2_ACCOUNT_ID=your_application_key_id
B2_ACCOUNT_KEY=your_application_key

# For S3-compatible backends, use these instead of the B2_* pair:
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...

# ---- Cache ------------------------------------------------------------------
# Explicit cache directory so restic's local cache persists across runs
# regardless of $HOME. This matters when running from systemd, where the
# service has no stable home directory — without it, restic may rebuild its
# cache from the remote every run and waste transactions.
RESTIC_CACHE_DIR=/var/cache/restic
